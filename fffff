active_session_code = [None]
timer_thread = [None]
running = [False]

def นับเวลา():
    while running[0]:
        code = active_session_code[0]
        if code and code in sessions:
            s = sessions[code]
            elapsed = time.time() - s["เริ่ม"]
            remaining = s["นาที"] * 60 - elapsed
            if remaining <= 0:
                running[0] = False
                s["active"] = False
                root.after(0, lambda: lbl_timer.config(text="00:00:00", fg=RED))
                root.after(0, lambda: lbl_status.config(
                    text="⛔ หมดเวลาแล้ว กรุณาติดต่อพนักงาน", fg=RED))
                root.after(0, refresh_table)
                break
            else:
                h, rem = divmod(int(remaining), 3600)
                m, sec = divmod(rem, 60)
                time_str = f"{h:02d}:{m:02d}:{sec:02d}"
                color = RED if remaining < 300 else (YELLOW if remaining < 600 else GREEN)
                root.after(0, lambda t=time_str, c=color: lbl_timer.config(text=t, fg=c))
                root.after(0, refresh_table)
        time.sleep(1)

def เริ่มเล่น():
    code = entry_code.get().strip().upper()
    if not code:
        messagebox.showwarning("รหัสว่าง", "กรุณาใส่รหัส")
        return
    if code not in sessions:
        lbl_status.config(text="❌ ไม่พบรหัสนี้ กรุณาติดต่อพนักงาน", fg=RED)
        return

    s = sessions[code]
    if s["active"]:
        lbl_status.config(text="⚠️ รหัสนี้กำลังใช้งานอยู่แล้ว", fg=YELLOW)
        return

    # เริ่มเซสชัน
    s["active"] = True
    s["เริ่ม"] = time.time()
    active_session_code[0] = code
    running[0] = True

    h, m = divmod(s["นาที"], 60)
    time_str = f"{h}ชม {m}น" if h > 0 else f"{m}น"
    lbl_status.config(text=f"✅ ยินดีต้อนรับ {s['ชื่อ']}! เครื่อง {s['เครื่อง']}", fg=GREEN)
    lbl_timer_info.config(text=f"เวลาเช่าทั้งหมด {time_str}")

    t = threading.Thread(target=นับเวลา, daemon=True)
    timer_thread[0] = t
    t.start()
    refresh_table()

