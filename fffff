def refresh_table():
    tree.delete(*tree.get_children())
    for code, s in sessions.items():
        if s["active"]:
            elapsed = time.time() - s["เริ่ม"]
            remaining = s["นาที"] * 60 - elapsed
            if remaining <= 0:
                s["active"] = False
                status = "หมดเวลา"
                remain_str = "00:00"
            else:
                m, sec = divmod(int(remaining), 60)
                remain_str = f"{m:02d}:{sec:02d}"
                status = "✅ ใช้งาน"
            tree.insert("", "end", values=(code, f"เครื่อง {s['เครื่อง']}", s['ชื่อ'], remain_str, status))

def ออกรหัส():
    machine = entry_machine.get().strip()
    name = entry_name.get().strip()
    minutes = entry_minutes.get().strip()
    price = entry_price.get().strip()

    if not machine or not name or not minutes:
        messagebox.showwarning("ข้อมูลไม่ครบ", "กรุณากรอกข้อมูลให้ครบ")
        return
    try:
        minutes = int(minutes)
        if minutes <= 0: raise ValueError
    except:
        messagebox.showerror("ข้อผิดพลาด", "กรุณากรอกเวลาเป็นตัวเลขที่ถูกต้อง")
        return

    code = สร้างรหัส()
    sessions[code] = {
        "เครื่อง": machine,
        "ชื่อ": name,
        "นาที": minutes,
        "เริ่ม": time.time(),
        "active": False  # ยังไม่ active จนกว่าลูกค้าจะใส่รหัส
    }

    lbl_result_code.config(text=f"🔑 {code}")
    h, m = divmod(minutes, 60)
    time_str = f"{h}ชม {m}น" if h > 0 else f"{m}น"
    lbl_result_info.config(
        text=f"เครื่อง {machine}  |  {name}  |  {time_str}  |  {price} บาท")
    refresh_table()

