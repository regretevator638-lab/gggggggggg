# ==================== ฟังก์ชันปุ่มลับ ====================
secret_clicks = [0]
secret_timer  = [None]

def คลิกปุ่มลับ(event=None):
    secret_clicks[0] += 1
    if secret_timer[0]:
        root.after_cancel(secret_timer[0])
    if secret_clicks[0] >= 5:
        secret_clicks[0] = 0
        แสดงหน้าต่างรหัสลับ()
    else:
        secret_timer[0] = root.after(3000, lambda: secret_clicks.__setitem__(0, 0))

def แสดงหน้าต่างรหัสลับ():
    win = tk.Toplevel(root)
    win.title("รหัสผู้ดูแล")
    win.configure(bg=BG_DARK)
    win.geometry("320x180")
    win.attributes("-topmost", True)
    win.grab_set()

    tk.Label(win, text="ใส่รหัสผู้ดูแลระบบ", font=("Segoe UI", 13, "bold"),
        bg=BG_DARK, fg=ACCENT).pack(pady=(20, 8))
    e = tk.Entry(win, font=("Courier New", 18, "bold"), bg=BG_FIELD, fg=ACCENT,
        show="*", justify="center", relief="flat",
        highlightthickness=1, highlightcolor=ACCENT, highlightbackground=BG_FIELD)
    e.pack(ipady=8, padx=30, fill="x")
    e.focus()
    lbl = tk.Label(win, text="", font=("Segoe UI", 10), bg=BG_DARK, fg=RED)
    lbl.pack(pady=4)

    def ตรวจรหัส(event=None):
        if e.get().strip().upper() == ADMIN_PASSWORD:
            win.destroy()
            root.destroy()
        else:
            lbl.config(text="❌ รหัสไม่ถูกต้อง")
            e.delete(0, "end")

    tk.Button(win, text="ยืนยัน", font=("Segoe UI", 11, "bold"),
        bg=ACCENT2, fg="white", relief="flat", padx=16, pady=6,
        command=ตรวจรหัส).pack(pady=6)
    e.bind("<Return>", ตรวจรหัส)

