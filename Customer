timer_win = None
current = {"code": None, "session": None, "total_sec": 0}
running = [False]

def สร้างหน้าต่างนาฬิกา():
    global timer_win
    timer_win = tk.Toplevel(root)
    timer_win.title("⏱ เวลาเหลือ")
    timer_win.geometry("280x130+20+20")
    timer_win.attributes("-topmost", True)
    timer_win.configure(bg=BG_DARK)
    timer_win.resizable(False, False)
    timer_win.protocol("WM_DELETE_WINDOW", lambda: None)
    timer_win.overrideredirect(True)  # ไม่มี title bar

    # กรอบ
    frame = tk.Frame(timer_win, bg=BG_CARD, padx=12, pady=8)
    frame.pack(fill="both", expand=True, padx=2, pady=2)

    tk.Label(frame, text="⏱ เวลาคงเหลือ", font=("Segoe UI", 9),
        bg=BG_CARD, fg=TEXT_SUB).pack()

    global lbl_mini_timer, lbl_mini_name, lbl_mini_status
    lbl_mini_timer = tk.Label(frame, text="00:00:00",
        font=("Courier New", 28, "bold"), bg=BG_CARD, fg=GREEN)
    lbl_mini_timer.pack()

    lbl_mini_name = tk.Label(frame, text="", font=("Segoe UI", 9),
        bg=BG_CARD, fg=TEXT_SUB)
    lbl_mini_name.pack()

    lbl_mini_status = tk.Label(frame, text="", font=("Segoe UI", 8),
        bg=BG_CARD, fg=GREEN)
    lbl_mini_status.pack()

    # ลากได้
    def เริ่มลาก(e):
        timer_win._drag_x = e.x
        timer_win._drag_y = e.y
    def ลาก(e):
        x = timer_win.winfo_x() + e.x - timer_win._drag_x
        y = timer_win.winfo_y() + e.y - timer_win._drag_y
        timer_win.geometry(f"+{x}+{y}")

    frame.bind("<Button-1>", เริ่มลาก)
    frame.bind("<B1-Motion>", ลาก)

    # คลิก 5 ครั้งเพื่อเปิดรหัสลับ
    frame.bind("<Double-Button-1>", คลิกปุ่มลับ)
    timer_win.bind("<Button-1>", คลิกปุ่มลับ)

# ==================== นับถอยหลัง ====================
def นับถอยหลัง():
    while running[0]:
        s = current["session"]
        if not s:
            break
        elapsed   = time.time() - s["เริ่ม"]
        remaining = s["นาที"] * 60 - elapsed
        total     = current["total_sec"]

        if remaining <= 0:
            running[0] = False
            s["active"] = False
            all_s = โหลด()
            all_s[current["code"]] = s
            บันทึก(all_s)
            root.after(0, หมดเวลา)
            break

        h, rem = divmod(int(remaining), 3600)
        m, sec  = divmod(rem, 60)
        ts = f"{h:02d}:{m:02d}:{sec:02d}"

        if remaining < 300:
            color = RED
            status = "⚠️ เหลือน้อยกว่า 5 นาที!"
        elif remaining < 600:
            color = YELLOW
            status = "⏰ เหลือน้อยกว่า 10 นาที"
        else:
            color = GREEN
            status = "✅ กำลังใช้งาน"

        def อัพเดท(t=ts, c=color, st=status):
            if timer_win and timer_win.winfo_exists():
                lbl_mini_timer.config(text=t, fg=c)
                lbl_mini_status.config(text=st, fg=c)

        root.after(0, อัพเดท)
        time.sleep(1)

def หมดเวลา():
    # ปิดหน้าต่างนาฬิกา
    global timer_win
    if timer_win and timer_win.winfo_exists():
        timer_win.destroy()
    timer_win = None
    # กลับหน้าล็อกเต็มจอ
    root.deiconify()
    root.attributes("-fullscreen", True)
    root.attributes("-topmost", True)
    e_code.delete(0, "end")
    lbl_err.config(text="⛔ หมดเวลาแล้ว กรุณาติดต่อพนักงาน", fg=RED)
    e_code.focus()
    current["code"] = None
    current["session"] = None

# ==================== เริ่มเล่น ====================
def เริ่มเล่น(event=None):
    code = e_code.get().strip().upper()
    if not code:
        lbl_err.config(text="กรุณาใส่รหัส", fg=RED)
        return

    sessions = โหลด()
    if code not in sessions:
        lbl_err.config(text="❌ ไม่พบรหัสนี้ กรุณาติดต่อพนักงาน", fg=RED)
        return

    s = sessions[code]
    if s.get("ใช้แล้ว"):
        lbl_err.config(text="🔒 รหัสนี้ถูกใช้ไปแล้ว ขอรหัสใหม่จากพนักงาน", fg=RED)
        return
    if s.get("active"):
        lbl_err.config(text="⚠️ รหัสนี้กำลังใช้งานอยู่แล้ว", fg=YELLOW)
        return

    s["active"]  = True
    s["ใช้แล้ว"] = True
    s["เริ่ม"]   = time.time()
    sessions[code] = s
    บันทึก(sessions)

    current["code"]      = code
    current["session"]   = s
    current["total_sec"] = s["นาที"] * 60

    h, m = divmod(s["นาที"], 60)
    t = f"{h}ชม {m}น" if h else f"{m}น"

    # ย่อหน้าล็อกลง taskbar แล้วให้ใช้คอมได้
    root.attributes("-fullscreen", False)
    root.attributes("-topmost", False)
    root.iconify()

    # สร้างหน้าต่างนาฬิกาเล็กๆ ลอยมุมจอ
    สร้างหน้าต่างนาฬิกา()
    lbl_mini_name.config(text=f"{s['ชื่อ']}  |  เครื่อง #{s['เครื่อง']}  |  {t}")

    running[0] = True
    threading.Thread(target=นับถอยหลัง, daemon=True).start()

tk.Button(frame_login, text="🎮 เริ่มเล่น", font=("Segoe UI", 16, "bold"),
