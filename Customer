# ==================== ปุ่มลับ (คลิก 5 ครั้ง) ====================
secret_clicks = [0]
secret_timer  = [None]

def คลิกปุ่มลับ(event=None):
    secret_clicks[0] += 1
    if secret_timer[0]:
        root.after_cancel(secret_timer[0])
    if secret_clicks[0] >= 5:
        secret_clicks[0] = 0
        แสดงหน้าต่างรหัสลับ()
    else:
        secret_timer[0] = root.after(3000, lambda: secret_clicks.__setitem__(0, 0))

