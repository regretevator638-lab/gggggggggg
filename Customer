# ==================== ฟังก์ชันหมดเวลา ====================
def หมดเวลา():
    running[0] = False
    s = current["session"]
    if s:
        s["active"] = False
        all_s = โหลด()
        all_s[current["code"]] = s
        บันทึก(all_s)
    # กลับหน้าล็อก
    root.after(0, กลับหน้าล็อก)

def กลับหน้าล็อก():
    frame_play.place_forget()
    frame_login.place(relx=0, rely=0, relwidth=1, relheight=1)
    e_code.delete(0, "end")
    lbl_err.config(text="⛔ หมดเวลาแล้ว กรุณาติดต่อพนักงานเพื่อซื้อเวลาเพิ่ม", fg=RED)
    e_code.focus()
    current["code"] = None
    current["session"] = None

# ==================== นับถอยหลัง ====================
def นับถอยหลัง():
    while running[0]:
        s = current["session"]
        if not s:
            break
        elapsed   = time.time() - s["เริ่ม"]
        remaining = s["นาที"] * 60 - elapsed
        total     = current["total_sec"]
        pct       = max(0, (remaining / total) * 100)

        if remaining <= 0:
            root.after(0, lambda: lbl_timer.config(text="00:00:00", fg=RED))
            root.after(0, lambda: progress.config(value=0))
            root.after(500, หมดเวลา)
            break

        h, rem = divmod(int(remaining), 3600)
        m, sec  = divmod(rem, 60)
        ts = f"{h:02d}:{m:02d}:{sec:02d}"

        if remaining < 300:
            color = RED
            style.configure("bar.Horizontal.TProgressbar", background=RED)
            root.after(0, lambda: lbl_status.config(text="⚠️ เหลือเวลาไม่ถึง 5 นาที!", fg=RED))
        elif remaining < 600:
            color = YELLOW
            style.configure("bar.Horizontal.TProgressbar", background=YELLOW)
            root.after(0, lambda: lbl_status.config(text="⏰ เหลือเวลาน้อยกว่า 10 นาที", fg=YELLOW))
        else:
            color = GREEN
            style.configure("bar.Horizontal.TProgressbar", background=GREEN)
            root.after(0, lambda: lbl_status.config(text="✅ กำลังใช้งาน", fg=GREEN))

        root.after(0, lambda t=ts, c=color: lbl_timer.config(text=t, fg=c))
        root.after(0, lambda p=pct: progress.config(value=p))
        time.sleep(1)

# ==================== เริ่มเล่น ====================
def เริ่มเล่น(event=None):
    code = e_code.get().strip().upper()
    if not code:
        lbl_err.config(text="กรุณาใส่รหัส", fg=RED)
        return

    sessions = โหลด()
    if code not in sessions:
        lbl_err.config(text="❌ ไม่พบรหัสนี้ กรุณาติดต่อพนักงาน", fg=RED)
        return

    s = sessions[code]
    if s.get("ใช้แล้ว"):
        lbl_err.config(text="🔒 รหัสนี้ถูกใช้ไปแล้ว ขอรหัสใหม่จากพนักงาน", fg=RED)
        return
    if s.get("active"):
        lbl_err.config(text="⚠️ รหัสนี้กำลังใช้งานอยู่แล้ว", fg=YELLOW)
        return

    s["active"]  = True
    s["ใช้แล้ว"] = True
    s["เริ่ม"]   = time.time()
    sessions[code] = s
    บันทึก(sessions)

    current["code"]      = code
    current["session"]   = s
    current["total_sec"] = s["นาที"] * 60

    h, m = divmod(s["นาที"], 60)
    t = f"{h}ชม {m}น" if h else f"{m}น"

    lbl_welcome.config(text=f"ยินดีต้อนรับ {s['ชื่อ']} 🎮")
    lbl_machine.config(text=f"เครื่อง #{s['เครื่อง']}")
    lbl_info_name.config(text=f"👤 ชื่อ: {s['ชื่อ']}")
    lbl_info_phone.config(text=f"📞 เบอร์: {s.get('เบอร์', '-')}")
    lbl_info_price.config(text=f"💰 ราคา: {s['ราคา']} บาท  |  เวลา: {t}")
    lbl_info_start.config(text=f"🕐 เริ่มเล่น: {datetime.now().strftime('%H:%M:%S')}")
    lbl_total.config(text=f"เวลาเช่าทั้งหมด {t}")
    lbl_timer.config(fg=GREEN)
    lbl_status.config(text="✅ กำลังใช้งาน", fg=GREEN)
    progress.config(value=100)

    frame_login.place_forget()
    frame_play.place(relx=0, rely=0, relwidth=1, relheight=1)

    running[0] = True
    threading.Thread(target=นับถอยหลัง, daemon=True).start()

tk.Button(frame_login, text="🎮 เริ่มเล่น", font=("Segoe UI", 16, "bold"),
