def อัพเดทตาราง():
    tree.delete(*tree.get_children())
    for code, s in sessions.items():
        status = "✅ ใช้งาน" if s["active"] else ("⏳ รอใช้" if not s.get("จบเมื่อ") else "🔒 สิ้นสุด")
        tag = "active" if s["active"] else ("waiting" if not s.get("จบเมื่อ") else "done")
        tree.insert("", "end", values=(
            code, f"#{s['เครื่อง']}", s['ชื่อ'], s.get('เบอร์','-'),
            s['นาที'], f"{s['ราคา']}฿", s['สร้างเมื่อ'], status), tags=(tag,))

