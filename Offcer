        messagebox.showwarning("ข้อมูลไม่ครบ", "กรุณากรอกข้อมูลให้ครบ")
        return
    try:
        mins = int(mins_str); price = int(price_str) if price_str else 0
    except:
        messagebox.showerror("ผิดพลาด", "เวลาและราคาต้องเป็นตัวเลข")
        return

    code = สร้างรหัส()
    s = {"เครื่อง": machine, "ชื่อ": name, "เบอร์": phone,
         "นาที": mins, "ราคา": price,
         "สร้างเมื่อ": datetime.now().strftime("%d/%m/%Y %H:%M"),
         "active": False}
    sessions[code] = s
    บันทึกข้อมูล(sessions)

    last_code[0] = code
    last_session[0] = s

    lbl_code.config(text=f"🔑  {code}", fg=ACCENT)
    h, m = divmod(mins, 60)
    t = f"{h}ชม {m}น" if h else f"{m}น"
    lbl_info.config(text=f"เครื่อง {machine}  •  {name}  •  {t}  •  {price} บาท", fg=TEXT)
