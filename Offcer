    receipt = f"""
╔══════════════════════════════╗
║       🎮 ร้านเกม GameZone      ║
╠══════════════════════════════╣
║ วันที่    : {now:<18} ║
║ ชื่อ      : {s['ชื่อ']:<18} ║
║ เบอร์     : {s.get('เบอร์','-'):<18} ║
