def สรุปรายได้():
    today = datetime.now().strftime("%d/%m/%Y")
    total_income = 0
    total_sessions = 0
    lines = [f"📅 รายงานวันที่ {today}\n{'─'*40}\n"]
    lines.append(f"{'รหัส':<8} {'ชื่อ':<12} {'เครื่อง':<8} {'เวลา':<8} {'ราคา':>8}\n")
    lines.append("─"*40 + "\n")
    for code, s in sessions.items():
        if s.get("สร้างเมื่อ","").startswith(today):
            h, m = divmod(s['นาที'], 60)
            t = f"{h}ชม{m}น" if h else f"{m}น"
            lines.append(f"{code:<8} {s['ชื่อ']:<12} #{s['เครื่อง']:<7} {t:<8} {s['ราคา']:>6}฿\n")
            total_income += s['ราคา']
            total_sessions += 1
    lines.append("─"*40 + "\n")
    lines.append(f"รวมทั้งหมด: {total_sessions} รายการ\n")
    lines.append(f"💰 รายได้รวม: {total_income} บาท\n")

    report_text.config(state="normal")
    report_text.delete("1.0", "end")
    report_text.insert("end", "".join(lines))
    report_text.config(state="disabled")

